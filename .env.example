# Alpaca API credentials (Paper Trading)
ALPACA_KEY_ID=your_paper_key_id_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Paper trading base URLs (do not change for paper mode)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Strategy parameters (optional overrides — defaults are set in config.js)
MAX_POSITIONS=5
MAX_POSITION_PCT=0.20
RISK_PER_TRADE_PCT=0.01
ATR_STOP_MULTIPLIER=1.5
HARD_STOP_FLOOR_PCT=0.015
SCALE_OUT_TARGET_PCT_CORE=0.05
SCALE_OUT_TARGET_PCT_SATELLITE=0.07
TRAILING_STOP_PCT=0.015
EOD_TIGHT_TRAIL_PCT=0.005
DAILY_PROFIT_TARGET_PCT=0.01
MIN_RELATIVE_VOLUME=2.0
MIN_GAP_UP_PCT=0.02
WATCHLIST_MAX_SIZE=50
ATR_PERIOD=14
VOLUME_BREAKOUT_MULTIPLIER=1.5
SIGNAL_BATCH_WINDOW_MS=10000
TRADE_DURING_LUNCH=false

# Observabilité — au moins un canal recommandé en production
# Discord : créer un webhook dans les paramètres d'un channel (Intégrations > Webhooks)
DISCORD_WEBHOOK_URL=

# Telegram : créer un bot via @BotFather, récupérer le token + chat_id via getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
